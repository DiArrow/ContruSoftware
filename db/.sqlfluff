[sqlfluff]
# Definimos el motor de base de datos
dialect = postgres
# Excluimos directorios si los hubiera
exclude_rules = none
# Límite de línea para los archivos SQL
max_line_length = 100

[sqlfluff:rules:capitalisation.keywords]
# Palabras clave (SELECT, FROM, WHERE) siempre en mayúsculas
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
# Tablas y columnas en minúsculas
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
# Funciones (COUNT, MAX, SUM) en mayúsculas
capitalisation_policy = upper

[sqlfluff:rules:layout.indent]
# Indentación a 4 espacios
indent_unit = space
tab_space_size = 4
